<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification icon for the status bar.
    Reproduces the app logo: cloud with paper airplane and motion marks.
    Optimized for small sizes without adaptive-icon padding.
    Android renders only the alpha channel as a monochrome silhouette.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Cloud (upper portion, slightly smaller than original ratio) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M6.5,13.5
                          C3.8,13.5 2,11.2 2,9
                          C2,7 3.4,5.4 5.3,5.1
                          C5.9,3 8.2,1.5 11,1.5
                          C13.5,1.5 15.7,3 16.5,5
                          C18.7,5.2 20.5,7.2 20.5,9.5
                          C20.5,11.8 18.5,13.5 16,13.5
                          Z" />

    <!-- Paper airplane (bottom-right) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M13,15 L22,18.5 L13,22 L15.5,18.5 Z" />

    <!-- Three motion marks (bottom-left, small swooshes) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M4,20.5 Q5,17.5 6,19.5
                          M7,20.5 Q8,17.5 9,19.5
                          M10,20.5 Q11,17.5 12,19.5" />
</vector>
